+<div class="right-panel-stack">
+  <section class="panel-card">
+    <h3>Saved Systems</h3>
+    <app-saved-systems></app-saved-systems>
+  </section>
+
+  <section class="panel-card">
+    <h3>Solution</h3>
+    <div *ngIf="response as resp; else emptySolution">
