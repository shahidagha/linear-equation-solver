+    elimination?: SolverStep[];
+    graphical_steps?: string[];
+    [key: string]: unknown;
+  };
+  graph: {
+    equation1_points: Array<[string | number, string | number]>;
+    equation2_points: Array<[string | number, string | number]>;
+    intersection: Record<string, string | number>;
+  };
+}
